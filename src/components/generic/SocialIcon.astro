---
interface Props {
  icon: 'github' | 'twitter' | 'linkedin' | 'rss';
  class?: string;
}

const { icon, class: className } = Astro.props;
---

<svg
  xmlns='http://www.w3.org/2000/svg'
  viewBox='0 0 24 24'
  fill='none'
  stroke='currentColor'
  stroke-width='1.8'
  stroke-linecap='round'
  stroke-linejoin='round'
  class={className}
  aria-hidden='true'
>
  {
    icon === 'github' && (
      <path d='M9 19c-4.5 1.5-4.5-2.5-6-3m12 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 19 4.77 5.07 5.07 0 0 0 18.91 1S17.73.65 15 2.48a13.38 13.38 0 0 0-6 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77 5.44 5.44 0 0 0 3.5 8.53c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22' />
    )
  }
  {
    icon === 'twitter' && (
      <path d='M22 5.8c-.7.3-1.5.5-2.3.7.8-.5 1.5-1.2 1.8-2.2-.8.5-1.7.8-2.6 1A4 4 0 0 0 12 8.1c0 .3 0 .6.1.9A11.3 11.3 0 0 1 3.9 4.8a4 4 0 0 0 1.2 5.3c-.6 0-1.2-.2-1.8-.5 0 1.9 1.3 3.5 3.1 3.9-.3.1-.7.1-1 .1-.2 0-.5 0-.8-.1.5 1.6 2 2.8 3.8 2.8A8.1 8.1 0 0 1 2 18.2a11.4 11.4 0 0 0 6.2 1.8c7.4 0 11.5-6.3 11.5-11.7v-.5c.8-.5 1.6-1.2 2.2-2Z' />
    )
  }
  {
    icon === 'linkedin' && (
      <>
        <path d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-12h4v2a4.8 4.8 0 0 1 4-2Z' />
        <path d='M2 9h4v12H2Z' />
        <circle cx='4' cy='4' r='2' fill='currentColor' stroke='none' />
      </>
    )
  }
  {
    icon === 'rss' && (
      <>
        <path d='M5 19a2 2 0 1 0 0 .01Z' />
        <path d='M4 11a9 9 0 0 1 9 9' />
        <path d='M4 4a16 16 0 0 1 16 16' />
      </>
    )
  }
</svg>
